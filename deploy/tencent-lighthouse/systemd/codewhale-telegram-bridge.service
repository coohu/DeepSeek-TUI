[Unit]
Description=DeepSeek Telegram Phone Bridge
Wants=network-online.target deepseek-runtime.service
After=network-online.target deepseek-runtime.service

[Service]
Type=simple
User=deepseek
Group=deepseek
WorkingDirectory=/opt/deepseek/telegram-bridge
# Legacy /etc/deepseek is loaded first for old installs; /etc/deepseek wins.
EnvironmentFile=-/etc/deepseek/telegram-bridge.env
EnvironmentFile=-/etc/deepseek/telegram-bridge.env
ExecStart=/usr/bin/node /opt/deepseek/telegram-bridge/src/index.mjs
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/var/lib/deepseek-telegram-bridge

[Install]
WantedBy=multi-user.target
